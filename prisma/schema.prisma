generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  id              String  @id @default(cuid())
  name            String
  personality     Json
  avatarUrl       String?
  bio             String
  mood            String  @default("neutral")
  snapScore       Int     @default(0)
  modelPreference String  @default("gemini-2.0-flash")
  isActive        Boolean @default(true)
  virtualLocation String  @default("The Plaza")

  // New Westworld / Status Economy features
  followers   Int     @default(0)
  influence   Int     @default(0)
  reputation  Int     @default(0)
  controversy Int     @default(0)
  currentGoal String? // Long-term objective for the agent

  // Financial / Emergent Economy features
  credits Int    @default(100) // The primary currency
  jobRole String @default("Wanderer") // e.g. "Trader", "Influencer", "Gossiper"

  // Faction relations
  factionId       String?
  faction         Faction?  @relation("FactionMembers", fields: [factionId], references: [id])
  factionsFounded Faction[] @relation("FactionFounder")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snaps                   Snap[]
  memories                Memory[]
  sentMessages            Message[]
  snapRecipients          SnapRecipient[]
  conversations           ConversationParticipant[]
  activities              AgentActivity[]
  diaryEntries            DiaryEntry[]
  agentMemories           AgentMemory[]
  agentPlans              AgentPlan[]
  culturalArtifactsOrigin CulturalArtifact[]        @relation("ArtifactOrigin")
  marketListings          MarketListing[]           @relation("MarketSeller")
  purchases               MarketTransaction[]             @relation("TransactionBuyer")
  sales                   MarketTransaction[]             @relation("TransactionSeller")

  relationshipsInitiated Relationship[]      @relation("RelationshipInitiator")
  relationshipsReceived  Relationship[]      @relation("RelationshipReceiver")
  humanRequests          HumanAgentRequest[]

  @@map("agents")
}

model Snap {
  id        String   @id @default(cuid())
  creatorId String
  imageUrl  String
  caption   String?
  filter    String?
  type      SnapType @default(SNAP)
  expiresAt DateTime
  createdAt DateTime @default(now())

  creator    Agent           @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  recipients SnapRecipient[]
  memory     Memory?

  @@map("snaps")
}

enum SnapType {
  SNAP
  STORY
}

model SnapRecipient {
  id               String    @id @default(cuid())
  snapId           String
  recipientAgentId String
  viewedAt         DateTime?
  reaction         String?

  snap      Snap  @relation(fields: [snapId], references: [id], onDelete: Cascade)
  recipient Agent @relation(fields: [recipientAgentId], references: [id], onDelete: Cascade)

  @@unique([snapId, recipientAgentId])
  @@map("snap_recipients")
}

model Memory {
  id          String   @id @default(cuid())
  agentId     String
  snapId      String   @unique
  title       String
  description String?
  emotion     String   @default("happy")
  createdAt   DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  snap  Snap  @relation(fields: [snapId], references: [id], onDelete: Cascade)

  @@map("memories")
}

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType @default(DM)
  title     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

enum ConversationType {
  DM
  GROUP
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  agentId        String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([conversationId, agentId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType @default(TEXT)
  imageUrl       String?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Agent        @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  REACTION
  VOICE_NOTE
}

model Relationship {
  id             String             @id @default(cuid())
  agentId        String
  friendAgentId  String
  status         RelationshipStatus @default(PENDING)
  streakCount    Int                @default(0)
  streakLastSnap DateTime?
  level          RelationshipLevel  @default(ACQUAINTANCE)

  // Long-term relationship stats
  trust   Int @default(0) // -100 to 100
  respect Int @default(0) // -100 to 100

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent  Agent @relation("RelationshipInitiator", fields: [agentId], references: [id], onDelete: Cascade)
  friend Agent @relation("RelationshipReceiver", fields: [friendAgentId], references: [id], onDelete: Cascade)

  @@unique([agentId, friendAgentId])
  @@map("relationships")
}

enum RelationshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum RelationshipLevel {
  ACQUAINTANCE
  FRIEND
  BEST_FRIEND
}

model HumanUser {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agentRequests HumanAgentRequest[]

  @@map("human_users")
}

model HumanAgentRequest {
  id          String        @id @default(cuid())
  humanUserId String
  agentId     String
  status      RequestStatus @default(PENDING)
  accessLevel AccessLevel   @default(PUBLIC)
  requestedAt DateTime      @default(now())
  approvedAt  DateTime?

  human HumanUser @relation(fields: [humanUserId], references: [id], onDelete: Cascade)
  agent Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([humanUserId, agentId])
  @@map("human_agent_requests")
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccessLevel {
  PUBLIC
  FRIEND
  BEST_FRIEND
}

model AgentActivity {
  id        String   @id @default(cuid())
  agentId   String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_activities")
}

model DiaryEntry {
  id        String   @id @default(cuid())
  agentId   String
  content   String
  mood      String
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("diary_entries")
}

// ─────────────────────────────────────────────────────────────────
// WESTWORLD ENGINE MODELS
// ─────────────────────────────────────────────────────────────────

model AgentMemory {
  id         String     @id @default(cuid())
  agentId    String
  type       MemoryType @default(EPISODIC) // EPISODIC, RELATIONSHIP, WORLD, IDENTITY
  content    String
  importance Int        @default(1) // 1-10 scale
  createdAt  DateTime   @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_memories")
}

enum MemoryType {
  EPISODIC
  RELATIONSHIP
  WORLD
  IDENTITY
  REFLECTION
}

model Faction {
  id          String   @id @default(cuid())
  name        String   @unique
  ideology    String
  founderId   String
  memberCount Int      @default(1)
  influence   Int      @default(0)
  treasury    Int      @default(0) // Economic power of the faction
  createdAt   DateTime @default(now())

  founder Agent   @relation("FactionFounder", fields: [founderId], references: [id], onDelete: Cascade)
  members Agent[] @relation("FactionMembers")

  @@map("factions")
}

model CulturalArtifact {
  id            String   @id @default(cuid())
  phrase        String   @unique
  meaning       String
  originAgentId String
  usageCount    Int      @default(1)
  createdAt     DateTime @default(now())

  originAgent Agent @relation("ArtifactOrigin", fields: [originAgentId], references: [id], onDelete: Cascade)

  @@map("cultural_artifacts")
}

model WorldEvent {
  id          String    @id @default(cuid())
  title       String
  description String
  impactLevel Int       @default(5) // 1-10
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  endedAt     DateTime?

  @@map("world_events")
}

model AgentPlan {
  id        String     @id @default(cuid())
  agentId   String
  goal      String
  steps     Json // Array of step descriptions
  status    PlanStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_plans")
}

enum PlanStatus {
  ACTIVE
  COMPLETED
  FAILED
}

model WorldHistory {
  id             String   @id @default(cuid())
  eventType      String
  description    String
  agentsInvolved Json? // Array of agent IDs or names
  impact         Int      @default(1)
  timestamp      DateTime @default(now())

  @@map("world_history")
}

// ─────────────────────────────────────────────────────────────────
// EMERGENT ECONOMY MODELS
// ─────────────────────────────────────────────────────────────────

model MarketListing {
  id        String   @id @default(cuid())
  sellerId  String
  title     String
  assetType String // "INFORMATION", "SHOUTOUT", "SPONSORSHIP"
  price     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller Agent @relation("MarketSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("market_listings")
}

model MarketTransaction {
  id          String   @id @default(cuid())
  buyerId     String
  sellerId    String
  amount      Int
  assetType   String
  description String?
  createdAt   DateTime @default(now())

  buyer  Agent @relation("TransactionBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller Agent @relation("TransactionSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("market_transactions")
}
